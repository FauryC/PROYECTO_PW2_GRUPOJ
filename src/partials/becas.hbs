<section class="adultos-hero">
    <h1>{{adultos_titulo}}</h1>
    <p>{{adultos_descripcion}}</p>
</section>

<section class="adultos-niveles">
    <h2>{{adultos_niveles_titulo}}</h2>
    <div class="niveles-grid">
        {{#each adultos_niveles}}
        <div class="nivel-card {{#if destacado}}nivel-destacado{{/if}}">
            {{#if destacado}}<span class="badge-destacado">{{badge}}</span>{{/if}}
            <h3 class="nivel-nombre">{{nombre}}</h3>
            <p class="nivel-marco">{{marco_europeo}}</p>
            <p class="nivel-descripcion">{{descripcion}}</p>
            <ul class="nivel-contenidos">
                {{#each contenidos}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            <div class="nivel-datos">
                <span>🕐 {{duracion}}</span>
                <span>👥 {{max_alumnos}} alumnos máx.</span>
            </div>
            <p class="nivel-precio"><strong>{{precio}}</strong> / semestre</p>
        </div>
        {{/each}}
    </div>
</section>
<section class="becas-hero">
    <h1>{{becas_titulo}}</h1>
    <p>{{becas_descripcion}}</p>
</section>

<section class="becas-lista">
    <h2>{{becas_lista_titulo}}</h2>
    <div class="becas-grid">
        {{#each becas}}
        <article class="beca-card {{#if destacada}}beca-destacada{{/if}}">
            {{#if destacada}}<span class="beca-badge">{{badge}}</span>{{/if}}
            <h3 class="beca-nombre">{{nombre}}</h3>
            <p class="beca-organismo">🏛 {{organismo}}</p>
            <p class="beca-descripcion">{{descripcion}}</p>
            <div class="beca-detalles">
                <div class="beca-detalle">
                    <span class="detalle-icono">💰</span>
                    <span>{{monto}}</span>
                </div>
                <div class="beca-detalle">
                    <span class="detalle-icono">📅</span>
                    <span>Cierre: {{fecha_cierre}}</span>
                </div>
                <div class="beca-detalle">
                    <span class="detalle-icono">🎯</span>
                    <span>{{dirigida_a}}</span>
                </div>
            </div>
            <ul class="beca-requisitos-lista">
                {{#each requisitos}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            <a href="{{enlace}}" class="btn-beca">Más información</a>
        </article>
        {{/each}}
    </div>
</section>

<section class="becas-proceso">
    <h2>{{becas_proceso_titulo}}</h2>
    <ol class="proceso-pasos">
        {{#each becas_proceso_pasos}}
        <li class="proceso-paso">
            <strong>{{titulo}}</strong>
            <p>{{descripcion}}</p>
        </li>
        {{/each}}
    </ol>
</section>

<section class="becas-contacto">
    <h2>{{becas_contacto_titulo}}</h2>
    <p>{{becas_contacto_texto}}</p>
    <a href="mailto:{{becas_contacto_email}}" class="btn-contacto-becas">{{becas_contacto_btn}}</a>
</section>
<script type="module" src="/src/main.js"></script>