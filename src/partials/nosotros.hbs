<section class="sobre-af">

    <div class="sobre-af-image"></div>
    <div class="sobre-af-overlay"></div>

    <div class="sobre-af-content">

        <h2 class="titulo-elegante">{{nosotros_titulo}}</h2>

        <p class="intro">{{nosotros_intro}}</p>

        <h3>{{nosotros_historia_titulo}}</h3>
        <p>{{nosotros_historia_texto}}</p>

        <h2 class="titulo-elegante">{{nosotros_mision_valores_titulo}}</h2>

        <div class="nosotros-grid">

            <div class="nosotros-card">
                <h3>{{nosotros_mision_titulo}}</h3>
                <p>{{nosotros_mision_texto}}</p>
            </div>

            <div class="nosotros-card">
                <h3>{{nosotros_valores_titulo}}</h3>
                <ul>
                    {{#each nosotros_valores}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
            </div>

        </div>

    </div>
</section>

<section class="cta-inscripcion">
    <h3>{{nosotros_cta_titulo}}</h3>
    <p>{{nosotros_cta_texto}}</p>
    <a href="{{nosotros_cta_btn_enlace}}" class="btn-primary">{{nosotros_cta_btn_texto}}</a>
</section>

<section class="nosotros-bloque">
    <h2 class="titulo-elegante">{{nosotros_comite_titulo}}</h2>

    <div class="team-grid">
        {{#each nosotros_comite}}
        <div class="team-card">
            <h3>{{nombre}}</h3>
            <p>{{cargo}}</p>
        </div>
        {{/each}}
    </div>
</section>

<section class="nosotros-bloque">
    <h2 class="titulo-elegante">{{nosotros_docentes_titulo}}</h2>

    <div class="team-grid">
        {{#each nosotros_docentes}}
        <div class="team-card"><h3>{{nombre}}</h3></div>
        {{/each}}
    </div>
</section>

<section class="nosotros-bloque">
    <h2 class="titulo-elegante">{{nosotros_instituciones_titulo}}</h2>

    <div class="team-grid">
        {{#each nosotros_instituciones}}
        <div class="team-card">
            <a href="{{url}}" target="_blank">
                <h3>{{nombre}}</h3>
            </a>
        </div>
        {{/each}}
    </div>
</section>

<script type="module" src="/src/main.js"></script>
