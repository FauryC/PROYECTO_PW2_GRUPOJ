<!-- BIENVENIDA -->
<link rel="shortcut icon" href="public/IMAGENES/logo.jpg" type="image/x-icon">
<section class="bienvenida">
    <h1>{{index_bienvenida_titulo}}</h1>
</section>

<!-- CARRUSEL -->
<section class="carousel-section">
    <div class="carousel" id="carousel">
        <div class="carousel-images">
            {{#each index_carrusel_items}}
            <div class="carousel-item">
                <img src="{{imagen}}" alt="{{alt}}">
                <p>{{caption}}</p>
            </div>
            {{/each}}
        </div>
        <button class="carousel-control-prev" onclick="moveSlide(-1)">&#10094;</button>
        <button class="carousel-control-next" onclick="moveSlide(1)">&#10095;</button>
    </div>
</section>

<!-- CONTADORES -->
<section class="contadores">
    {{#each index_contadores}}
    <div class="contador-item">
        <img src="{{icono}}">
        <span>{{numero}}</span>
        <p>{{descripcion}}</p>
    </div>
    {{/each}}
</section>

<!-- MISIÓN -->
<section class="panel1">
    <div>
        <img src="{{index_mision_logo}}" width="189">
        <h3>{{index_mision_titulo}}</h3>
        <p>{{index_mision_texto}}</p>
    </div>
</section>

<!-- NOTICIAS -->
<section class="noticias">
    <h2 class="titulo-noticias">{{index_noticias_titulo}}</h2>

    <div class="noticias-grid">
        {{#each index_noticias}}
        <article class="noticia-card">
            <img src="{{imagen}}">
            <h3>{{titulo}}</h3>
            <p>{{texto}}</p>
            <a href="{{enlace}}" target="_blank" class="leer-mas">{{enlace_texto}}</a>
        </article>
        {{/each}}
    </div>
</section>

<script>
(function () {
    let currentSlide = 0;
    let autoplayTimer = null;
    const AUTOPLAY_DELAY = 4000;

    function moveSlide(direction) {
        const images = document.querySelector('#carousel .carousel-images');
        const items  = document.querySelectorAll('#carousel .carousel-item');
        if (!images || items.length === 0) return;

        currentSlide = (currentSlide + direction + items.length) % items.length;
        images.style.transform = 'translateX(-' + (currentSlide * 100) + '%)';
    }

    function startAutoplay() {
        autoplayTimer = setInterval(function () { moveSlide(1); }, AUTOPLAY_DELAY);
    }

    function stopAutoplay() {
        clearInterval(autoplayTimer);
    }

    window.moveSlide = moveSlide;

    document.addEventListener('DOMContentLoaded', function () {
        const carousel = document.getElementById('carousel');
        if (!carousel) return;
        startAutoplay();
        carousel.addEventListener('mouseenter', stopAutoplay);
        carousel.addEventListener('mouseleave', startAutoplay);
    });
})();
</script>
<script type="module" src="/src/main.js"></script>
